# Solo-LTR detection.
# gen5400000_final.fasta is PrinTE genome with LTR-RTs only (intact, solo-, and fragmented).
# gen5400000_final.fasta_r1_ltr.fa are re-detected non-nest LTR-RTs with 'ltrharvest_wrapper2.sh'.
# I used Kmer2LTR to create the LTR consensus file (Kmer2LTR_run.consensus.fa) of gen5400000_final.fasta_r1_ltr.fa.
bash synLTR/module2/solo_LTR/solo_ltr_pipeline.sh -g gen5400000_final.fasta -i gen5400000_final.fasta_r1_ltr.fa -q Kmer2LTR_run.consensus.fa -o solo_ltr_test_minimap -p solo_ltr_test_minimap2 -a minimap22 -f 10 -M 50 -C 0.9 -T 5 -W 1 -X 0 -t 132 -v

